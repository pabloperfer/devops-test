// Jenkinsfile (refactored using shared libraries)
@Library('shared-lib') _

pipeline {
  parameters {
    booleanParam(name: 'DESTROY', defaultValue: false, description: 'Destroy the entire EKS stack instead of deploying')
  }

  agent any

  environment {
    AWS_REGION  = 'us-east-1'
    ACCOUNT_ID  = '679349556244'
    ECR_REPO    = 'sample-node-app'
    AWS_PROFILE = 'terraform-assume-role'
    KUBECONFIG  = "${env.WORKSPACE}/.kubeconfig"
    CHART_DIR   = 'helm-chart'
    RELEASE     = 'sample-node-app'
  }

  stages {
    stage('Cleanup workspace') {
      steps { cleanWs() }
    }

    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Destroy stack') {
      when { expression { params.DESTROY } }
      steps { destroyStack(env.RELEASE, env.KUBECONFIG, env.AWS_REGION) }
    }

    stage('Stop after Destroy') {
      when { expression { params.DESTROY } }
      steps { echo 'Stack destroyed , finishing pipeline.' }
    }

    stage('Set Image Tag') {
      when { not { expression { params.DESTROY } } }
      steps {
        script {
          def ts = sh(script: 'date +%Y%m%d%H%M%S', returnStdout: true).trim()
          env.IMAGE_TAG  = "build-${BUILD_NUMBER}-${ts}"
          env.ECR_URI    = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}"
          env.FULL_IMAGE = "${env.ECR_URI}:${env.IMAGE_TAG}"
          echo "Image to build →  ${env.FULL_IMAGE}"
        }
      }
    }

    stage('Terraform Apply') {
      when { not { expression { params.DESTROY } } }
      steps { terraformApply('terraform', 'dev.tfvars') }
    }

    stage('Lint & Test') {
      when { not { expression { params.DESTROY } } }
      steps { lintAndTest(env.CHART_DIR) }
    }

    stage('Build Image') {
      when { not { expression { params.DESTROY } } }
      steps { buildDockerImage('app', env.FULL_IMAGE) }
    }

    stage('Push to ECR') {
      when { not { expression { params.DESTROY } } }
      steps { pushDockerImage(env.ECR_URI, env.FULL_IMAGE, env.AWS_REGION) }
    }

    stage('Configure kubectl') {
      when { not { expression { params.DESTROY } } }
      steps { configureKubectl(env.AWS_REGION, env.KUBECONFIG) }
    }

    stage('Helm Deploy') {
      when { not { expression { params.DESTROY } } }
      steps {
        helmDeploy(env.RELEASE, env.CHART_DIR, env.ECR_URI, env.IMAGE_TAG, env.KUBECONFIG)
      }
    }
  }

  post {
    always {
      cleanWs(deleteDirs: true)
      echo 'Pipeline finished.'
    }
    failure {
      cleanWs(deleteDirs: true)
      echo ' Pipeline failed check logs!'
    }
  }
}